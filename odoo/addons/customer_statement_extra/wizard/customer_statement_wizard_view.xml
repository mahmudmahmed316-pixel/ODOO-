<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_statement_wizard_form" model="ir.ui.view">
        <field name="name">customer.statement.wizard.form</field>
        <field name="model">customer.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Statement Details">
                <header>
                    <button name="action_print" string="Print PDF" type="object" class="btn-primary" icon="fa-print"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3><field name="partner_id" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Sales Information">
                            <field name="sales_count"/>
                            <field name="total_sales_amount" widget="monetary"/>
                        </group>
                        <group string="Financial Summary">
                            <field name="total_payments_amount" widget="monetary"/>
                            <field name="balance" widget="monetary" decoration-danger="balance &gt; 0"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sales Details" name="sales_details">
                            <field name="sale_order_ids" readonly="1" options="{'no_open': True, 'no_create': True}">
                                <list create="0" delete="0" edit="0" decoration-bf="1">
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="amount_total" sum="Total Sales"/>
                                    <field name="state" widget="badge" decoration-info="state == 'sale'" decoration-success="state == 'done'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payment Details" name="payment_details">
                            <field name="payment_ids" readonly="1" options="{'no_open': True, 'no_create': True}">
                                <list create="0" delete="0" edit="0" decoration-bf="1">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="journal_id"/>
                                    <field name="amount" sum="Total Payments"/>
                                    <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'in_process'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <p class="text-muted">
                        Review the summary above before printing the official statement.
                    </p>
                </sheet>
                <footer>
                    <button name="action_print" string="Print PDF" type="object" class="btn-primary" icon="fa-print"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
