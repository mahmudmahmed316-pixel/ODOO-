<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_statement_extra" model="ir.ui.view">
        <field name="name">res.partner.form.statement.extra</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_print_customer_statement" type="object" class="oe_stat_button" icon="fa-file-text-o">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Customer</span>
                        <span class="o_stat_text">Statement</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Statement Summary" name="statement_summary" groups="account.group_account_invoice">
                    <group>
                        <group>
                            <field name="customer_sales_count" readonly="1"/>
                            <field name="customer_total_sales_amount" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_payments_amount" widget="monetary" readonly="1"/>
                            <field name="customer_balance" widget="monetary" readonly="1" decoration-danger="customer_balance &gt; 0" decoration-success="customer_balance &lt;= 0"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
