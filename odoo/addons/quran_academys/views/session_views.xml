<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Session Tree View -->
        <record id="view_academy_session_tree" model="ir.ui.view">
            <field name="name">academy.session.tree</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <list string="Sessions">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="course_id"/>
                    <field name="teacher_id"/>
                    <field name="topic"/>
                    <field name="meeting_link" widget="url"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <!-- Session Form View -->
        <record id="view_academy_session_form" model="ir.ui.view">
            <field name="name">academy.session.form</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <form string="Session">
                    <header>
                        <button name="action_done" string="Mark as Done" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'draft'"/>
                        <button name="action_draft" string="Set to Draft" type="object" invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="course_id" readonly="state != 'draft'"/>
                                <field name="teacher_id"/>
                                <field name="topic" placeholder="e.g. Surat Al-Baqarah (1-10)"/>
                            </group>
                            <group>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="meeting_link" widget="url"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Student Evaluations">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list editable="bottom" decoration-info="status_color == 'blue'" decoration-success="status_color == 'green'" decoration-warning="status_color == 'yellow'" decoration-danger="status_color == 'red'" decoration-muted="status_color == 'gray'">
                                        <field name="student_id"/>
                                        <field name="attendance" widget="radio" options="{'horizontal': true}"/>
                                        <button name="action_mark_present" type="object" icon="fa-check text-success" title="Mark Present" invisible="attendance == 'present'"/>
                                        <button name="action_mark_absent" type="object" icon="fa-times text-danger" title="Mark Absent" invisible="attendance == 'absent'"/>
                                        <field name="subscription_id"/>
                                        <field name="homework_done"/>
                                        <field name="recitation_level"/>
                                        <field name="memorization"/>
                                        <field name="session_rating"/>
                                        <field name="notes"/>
                                        <field name="next_homework"/>
                                        <field name="status_color" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Session Calendar View -->
        <record id="view_academy_session_calendar" model="ir.ui.view">
            <field name="name">academy.session.calendar</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <calendar string="Sessions" date_start="date" color="course_id" mode="week">
                    <field name="name"/>
                    <field name="course_id"/>
                    <field name="teacher_id"/>
                    <field name="topic"/>
                </calendar>
            </field>
        </record>

        <!-- Session Pivot View for Teacher Reports -->
        <record id="view_academy_session_pivot" model="ir.ui.view">
            <field name="name">academy.session.pivot</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <pivot string="Sessions Analysis" sample="1">
                    <field name="teacher_id" type="row"/>
                    <field name="date" interval="month" type="col"/>
                </pivot>
            </field>
        </record>

        <!-- Session Graph View -->
        <record id="view_academy_session_graph" model="ir.ui.view">
            <field name="name">academy.session.graph</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <graph string="Sessions Analysis" type="bar" sample="1">
                    <field name="teacher_id"/>
                    <field name="date" interval="month"/>
                </graph>
            </field>
        </record>

        <!-- Action for Session -->
        <record id="action_academy_session" model="ir.actions.act_window">
            <field name="name">Sessions</field>
            <field name="res_model">academy.session</field>
            <field name="view_mode">list,calendar,pivot,graph,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Log your first session!</p>
            </field>
        </record>

        <!-- Action for Reporting -->
        <record id="action_academy_reporting" model="ir.actions.act_window">
            <field name="name">Reporting</field>
            <field name="res_model">academy.session</field>
            <field name="view_mode">pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_empty_folder">Analyze your sessions performance here.</p>
            </field>
        </record>

        <!-- Menu for Session -->
        <menuitem id="menu_academy_session"
                  name="Sessions"
                  parent="menu_academy_operations"
                  action="action_academy_session"
                  sequence="20"/>

        <!-- Reporting Menu -->
        <menuitem id="menu_academy_reporting"
                  name="Reporting"
                  parent="menu_quran_academy_root"
                  action="action_academy_reporting"
                  sequence="50"
                  groups="quran_academys.group_academy_manager,quran_academys.group_academy_teacher"/>
    </data>
</odoo>

