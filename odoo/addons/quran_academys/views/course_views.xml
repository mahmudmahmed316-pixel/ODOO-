<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Course Tree View -->
        <record id="view_academy_course_tree" model="ir.ui.view">
            <field name="name">academy.course.tree</field>
            <field name="model">academy.course</field>
            <field name="arch" type="xml">
                <list string="Courses">
                    <field name="name"/>
                    <field name="teacher_id"/>
                </list>
            </field>
        </record>

        <!-- Course Form View -->
        <record id="view_academy_course_form" model="ir.ui.view">
            <field name="name">academy.course.form</field>
            <field name="model">academy.course</field>
            <field name="arch" type="xml">
                <form string="Course">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Course Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="teacher_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Students">
                                <field name="student_ids" widget="many2many">
                                    <list>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Sessions">
                                <field name="session_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Course -->
        <record id="action_academy_course" model="ir.actions.act_window">
            <field name="name">Courses</field>
            <field name="res_model">academy.course</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu for Course -->
        <menuitem id="menu_academy_course"
                  name="Courses"
                  parent="menu_academy_configuration"
                  action="action_academy_course"
                  sequence="10"/>
    </data>
</odoo>

