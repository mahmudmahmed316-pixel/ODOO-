<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_academy_subscription_list" model="ir.ui.view">
            <field name="name">academy.subscription.list</field>
            <field name="model">academy.subscription</field>
            <field name="arch" type="xml">
                <list string="Subscriptions">
                    <field name="student_id"/>
                    <field name="name"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="allowed_sessions"/>
                    <field name="remaining_sessions"/>
                    <field name="price"/>
                    <field name="payment_state" widget="badge" decoration-success="payment_state == 'paid'"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'draft'" decoration-danger="state in ('expired', 'cancelled')"/>
                </list>
            </field>
        </record>

        <record id="view_academy_subscription_form" model="ir.ui.view">
            <field name="name">academy.subscription.form</field>
            <field name="model">academy.subscription</field>
            <field name="arch" type="xml">
                <form string="Subscription">
                    <header>
                        <button name="action_active" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_create_invoice" string="Create Invoice" type="object" class="oe_highlight" invisible="invoice_id != False"/>
                        <button name="action_expire" string="Set Expired" type="object" invisible="state != 'active'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'active')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,active,expired"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="student_id" readonly="state != 'draft'"/>
                                <field name="start_date" readonly="state != 'draft'"/>
                                <field name="end_date" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="allowed_sessions" readonly="state != 'draft'"/>
                                <field name="attended_sessions"/>
                                <field name="remaining_sessions" decoration-danger="remaining_sessions == 0"/>
                            </group>
                            <group>
                                <field name="price"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="invoice_id"/>
                                <field name="payment_state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Attended Sessions">
                                <field name="session_line_ids" readonly="1">
                                    <list>
                                        <field name="session_id"/>
                                        <field name="attendance"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Scheduled Sessions (Optional)">
                                <field name="session_schedule_ids">
                                    <list editable="bottom">
                                        <field name="session_date"/>
                                        <field name="topic"/>
                                        <field name="meeting_link" widget="url"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_academy_subscription" model="ir.actions.act_window">
            <field name="name">Subscriptions</field>
            <field name="res_model">academy.subscription</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_academy_subscription"
                  name="Subscriptions"
                  parent="menu_academy_operations"
                  action="action_academy_subscription"
                  sequence="15"/>
    </data>
</odoo>
