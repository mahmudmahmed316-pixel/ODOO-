<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_session_reminder" model="mail.template">
            <field name="name">Session: Reminder</field>
            <field name="model_id" ref="model_academy_session"/>
            <field name="subject">Reminder: Your session {{ object.name }} is starting soon!</field>
            <field name="email_from">{{ (object.teacher_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.line_ids.mapped('student_id.partner_id.id') | join(',') }}</field>
            <field name="description">Sent to students 15 minutes before session starts</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello,
                        <br/><br/>
                        This is a reminder that your session <strong><t t-out="object.name"/></strong> is starting in 15 minutes.
                        <br/><br/>
                        <strong>Course:</strong> <t t-out="object.course_id.name"/><br/>
                        <strong>Date:</strong> <t t-out="object.date" t-options='{"widget": "datetime"}'/><br/>
                        
                        <t t-if="object.meeting_link">
                            <br/>
                            <strong>Meeting Link:</strong> <a t-att-href="object.meeting_link" style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">Join Now</a>
                            <br/><br/>
                        </t>
                        
                        Best regards,<br/>
                        Quran Academy Team
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>
